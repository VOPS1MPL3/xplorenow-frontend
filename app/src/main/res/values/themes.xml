<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.XploreNow" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Paleta XploreNow - Tierra/Explorador.
             colorPrimary lo usan automaticamente los MaterialToolbar
             que tienen android:background="?attr/colorPrimary". -->
        <item name="colorPrimary">@color/terracota</item>
        <item name="colorPrimaryDark">@color/terracota_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorAccent">@color/verde_militar</item>

        <!-- Fondo general de la app -->
        <item name="android:windowBackground">@color/bg_app</item>
        <item name="android:colorBackground">@color/bg_app</item>

        <!-- Status bar matcheando el toolbar -->
        <item name="android:statusBarColor">@color/terracota_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Estilo por default de los <Button>: terracota con texto crema -->
        <item name="materialButtonStyle">@style/XploreNow.Button</item>
    </style>

    <!-- Boton primario: terracota relleno -->
    <style name="XploreNow.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/terracota</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="rippleColor">#33FFFFFF</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Boton outline: borde terracota, texto terracota -->
    <style name="XploreNow.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/terracota</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/terracota</item>
        <item name="rippleColor">#33C8623F</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Boton secundario: verde militar (para "Ver historial", "Editar preferencias", etc.) -->
    <style name="XploreNow.Button.Secondary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/verde_militar</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="rippleColor">#33FFFFFF</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Theme.XploreNow" parent="Base.Theme.XploreNow" />

    <style name="Theme.XploreNow.Splash" parent="Theme.XploreNow">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/crema_clara</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="XploreNow.Button.Reservar" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/verde_militar</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:minHeight">52dp</item>
        <item name="rippleColor">#33FFFFFF</item>
        <item name="cornerRadius">8dp</item>
        <item name="elevation">0dp</item>
    </style>
</resources>