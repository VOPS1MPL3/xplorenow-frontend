<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="XploreNow"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textEmailAddress"
        android:hint="Email"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textPassword"
        android:hint="Contraseña"
        android:layout_marginBottom="8dp"/>

    <!-- Link a la recuperacion de contrasena: alineado a la derecha,
         sutil y con color de acento para que se note como link clickeable. -->
    <TextView
        android:id="@+id/tvOlvideContrasena"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿Olvidaste tu contraseña?"
        android:textColor="#A78BFA"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="end"
        android:padding="8dp"
        android:layout_marginBottom="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground" />

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Iniciar sesión"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnIrOtp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ingresar con código OTP"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Crear cuenta nueva"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnBiometria"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ingresar con huella"
        android:visibility="gone"/>

</LinearLayout>
