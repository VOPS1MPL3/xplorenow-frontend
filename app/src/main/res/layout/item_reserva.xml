<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/ivImagen"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:contentDescription="Imagen actividad"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            tools:text="Free Tour por San Telmo"
            app:layout_constraintTop_toTopOf="@id/ivImagen"
            app:layout_constraintStart_toEndOf="@id/ivImagen"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvFechaHora"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            tools:text="2026-05-15 - 10:00"
            app:layout_constraintTop_toBottomOf="@id/tvNombre"
            app:layout_constraintStart_toEndOf="@id/ivImagen"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvParticipantes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            tools:text="2 participantes"
            app:layout_constraintTop_toBottomOf="@id/tvFechaHora"
            app:layout_constraintStart_toEndOf="@id/ivImagen"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@color/verde_militar"
            tools:text="CONFIRMADA"
            app:layout_constraintTop_toBottomOf="@id/tvParticipantes"
            app:layout_constraintStart_toEndOf="@id/ivImagen" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>