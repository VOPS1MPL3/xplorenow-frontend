<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        app:title="Historial"
        app:titleTextColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Filtros: fondo oscuro consistente con el resto de la app, en lugar
         del card blanco que generaba contraste roto con el toolbar lila. -->
    <LinearLayout
        android:id="@+id/llFiltros"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#2A1F45"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Destino"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@android:color/white" />

        <!-- Spinner forzado a tema oscuro: backgroundTint asegura que la flecha
             y el indicador queden lila en lugar del gris default. El popup se
             configura via popupBackground para que el menu desplegable tampoco
             quede blanco. -->
        <Spinner
            android:id="@+id/spDestino"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:backgroundTint="#A78BFA"
            android:popupBackground="#2A1F45" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <!-- Las "fechas" son TextViews que abren un DatePicker. Las dejamos
                 con background sutil, texto blanco y hint claro para que se
                 lean sobre el fondo violeta. -->
            <TextView
                android:id="@+id/tvFechaDesde"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:padding="12dp"
                android:background="#3D2E5F"
                android:hint="Desde"
                android:textColor="@android:color/white"
                android:textColorHint="#B0A8C8"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvFechaHasta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="12dp"
                android:background="#3D2E5F"
                android:hint="Hasta"
                android:textColor="@android:color/white"
                android:textColorHint="#B0A8C8"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <!-- Boton "Limpiar": estilo borderless con texto lila para que NO
                 herede el fondo lila relleno del materialButtonStyle global. -->
            <Button
                android:id="@+id/btnLimpiar"
                style="?attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Limpiar"
                android:textColor="#A78BFA" />

            <!-- Boton "Aplicar": hereda XploreNow.Button (lila relleno). -->
            <Button
                android:id="@+id/btnAplicar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Aplicar" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cargando..."
        android:textSize="16sp"
        android:textColor="#B0A8C8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llFiltros" />

    <ListView
        android:id="@+id/lvHistorial"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="6dp"
        android:visibility="gone"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llFiltros" />

</androidx.constraintlayout.widget.ConstraintLayout>
