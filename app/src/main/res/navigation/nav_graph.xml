<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.xplorenow.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_otpSolicitar"
            app:destination="@id/otpSolicitarFragment"/>
        <action
            android:id="@+id/action_login_to_registro"
            app:destination="@id/registroFragment"/>
        <action
            android:id="@+id/action_login_to_olvide"
            app:destination="@id/olvideContrasenaFragment"/>
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/otpSolicitarFragment"
        android:name="com.xplorenow.auth.OtpSolicitarFragment"
        android:label="OTP Solicitar"
        tools:layout="@layout/fragment_otp_solicitar">
        <action
            android:id="@+id/action_otpSolicitar_to_otpConfirmar"
            app:destination="@id/otpConfirmarFragment"/>
    </fragment>

    <fragment
        android:id="@+id/otpConfirmarFragment"
        android:name="com.xplorenow.auth.OtpConfirmarFragment"
        android:label="OTP Confirmar"
        tools:layout="@layout/fragment_otp_confirmar">
        <argument
            android:name="email"
            app:argType="string"
            android:defaultValue=""/>
        <action
            android:id="@+id/action_otpConfirmar_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/registroFragment"
        android:name="com.xplorenow.auth.RegistroFragment"
        android:label="Registro"
        tools:layout="@layout/fragment_registro">
        <action
            android:id="@+id/action_registro_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.xplorenow.ui.home.HomeFragment"
        android:label="Inicio"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_detalle"
            app:destination="@id/detalleFragment" />
        <action
            android:id="@+id/action_home_to_filtros"
            app:destination="@id/filtrosFragment" />
        <action
            android:id="@+id/action_home_to_noticiaDetalle"
            app:destination="@id/noticiaDetalleFragment" />
        <action
            android:id="@+id/action_home_to_perfil"
            app:destination="@id/perfilFragment" />
        <action
            android:id="@+id/action_home_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false"/>
    </fragment>

    <fragment
        android:id="@+id/detalleFragment"
        android:name="com.xplorenow.ui.home.detalle.DetalleFragment"
        android:label="Detalle"
        tools:layout="@layout/fragment_detalle">
        <argument
            android:name="actividadId"
            app:argType="long" />
        <action
            android:id="@+id/action_detalle_to_horarios"
            app:destination="@id/horariosFragment" />
    </fragment>

    <!-- Mis Favoritos (Punto 7 del TPO) -->
    <fragment
        android:id="@+id/favoritosFragment"
        android:name="com.xplorenow.ui.home.favoritos.FavoritosFragment"
        android:label="Mis favoritos"
        tools:layout="@layout/fragment_favoritos">
        <action
            android:id="@+id/action_favoritos_to_detalle"
            app:destination="@id/detalleFragment" />
    </fragment>

    <fragment
        android:id="@+id/filtrosFragment"
        android:name="com.xplorenow.ui.home.filtros.FiltrosFragment"
        android:label="Filtros"
        tools:layout="@layout/fragment_filtros" />

    <fragment
        android:id="@+id/misReservasFragment"
        android:name="com.xplorenow.ui.home.misreservas.MisReservasFragment"
        android:label="Mis reservas"
        tools:layout="@layout/fragment_mis_reservas">
        <action
            android:id="@+id/action_misReservas_to_reservaDetalle"
            app:destination="@id/reservaDetalleFragment" />
    </fragment>

    <fragment
        android:id="@+id/reservaDetalleFragment"
        android:name="com.xplorenow.ui.home.misreservas.detalle.ReservaDetalleFragment"
        android:label="Detalle de reserva"
        tools:layout="@layout/fragment_reserva_detalle">
        <argument
            android:name="reservaId"
            app:argType="long" />
        <action
            android:id="@+id/action_reservaDetalle_to_calificacion"
            app:destination="@id/calificacionFragment" />
    </fragment>

    <fragment
        android:id="@+id/historialFragment"
        android:name="com.xplorenow.ui.home.historial.HistorialFragment"
        android:label="Historial"
        tools:layout="@layout/fragment_historial">
        <action
            android:id="@+id/action_historial_to_reservaDetalle"
            app:destination="@id/reservaDetalleFragment" />
    </fragment>

    <fragment
        android:id="@+id/horariosFragment"
        android:name="com.xplorenow.ui.home.detalle.HorariosFragment"
        android:label="Seleccionar horario"
        tools:layout="@layout/fragment_horarios">
        <argument
            android:name="actividadId"
            app:argType="long" />
        <action
            android:id="@+id/action_horarios_to_reservaDetalle"
            app:destination="@id/reservaDetalleFragment" />
    </fragment>

    <fragment
        android:id="@+id/calificacionFragment"
        android:name="com.xplorenow.ui.home.calificacion.CalificacionFragment"
        android:label="Calificar actividad"
        tools:layout="@layout/fragment_calificacion">
        <argument
            android:name="reservaId"
            app:argType="long" />
        <argument
            android:name="actividadNombre"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/noticiaDetalleFragment"
        android:name="com.xplorenow.ui.home.noticia.NoticiaDetalleFragment"
        android:label="Noticia"
        tools:layout="@layout/fragment_noticia_detalle">
        <argument
            android:name="noticiaId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/perfilFragment"
        android:name="com.xplorenow.ui.profile.PerfilFragment"
        android:label="Perfil"
        tools:layout="@layout/fragment_perfil">
        <action
            android:id="@+id/action_perfil_to_preferencias"
            app:destination="@id/preferenciasFragment" />
        <action
            android:id="@+id/action_perfil_to_historial"
            app:destination="@id/historialFragment" />
        <action
            android:id="@+id/action_perfil_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/preferenciasFragment"
        android:name="com.xplorenow.ui.profile.PreferenciasFragment"
        android:label="Preferencias"
        tools:layout="@layout/fragment_preferencias" />

    <!-- ===== Recuperacion de contrasena (Punto 1, extension) ===== -->

    <fragment
        android:id="@+id/olvideContrasenaFragment"
        android:name="com.xplorenow.auth.OlvideContrasenaFragment"
        android:label="Recuperar contraseña"
        tools:layout="@layout/fragment_olvide_contrasena">
        <action
            android:id="@+id/action_olvide_to_reset"
            app:destination="@id/resetPasswordFragment" />
    </fragment>

    <fragment
        android:id="@+id/resetPasswordFragment"
        android:name="com.xplorenow.auth.ResetPasswordFragment"
        android:label="Nueva contraseña"
        tools:layout="@layout/fragment_reset_password">
        <argument
            android:name="email"
            app:argType="string"
            android:defaultValue="" />
        <!-- Al guardar la nueva contrasena volvemos al login limpiando el
             stack de pantallas de recuperacion (olvide + reset). -->
        <action
            android:id="@+id/action_reset_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>